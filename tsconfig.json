{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@components/*": ["src/components/*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "content/**/*", ".astro/types.d.ts"],
  "exclude": ["node_modules", "dist"]
}
