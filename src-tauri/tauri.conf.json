{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deutsch-Atlas",
  "version": "0.2.0",
  "identifier": "dev.nonvision.deutsch-atlas",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:4321",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Deutsch-Atlas",
        "width": 1100,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
