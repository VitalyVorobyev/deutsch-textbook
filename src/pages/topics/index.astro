---
import Base from '../../layouts/Base.astro';
import Chrome from '../../components/Chrome.astro';
import CurriculumPath from '../../components/atlas/CurriculumPath';
import { getCheckpoints, getTopicNodes } from '../../lib/content';
import { getCurriculum } from '../../lib/curriculum';

const curriculum = getCurriculum();
const topicNodes = await getTopicNodes();
const topicById = new Map(topicNodes.map((topic) => [topic.id, topic]));
const graphById = new Map(curriculum.nodes.map((node) => [node.id, node]));

const units = curriculum.units.map((unit) => ({
  ...unit,
  topics: unit.topics.map((id) => {
    const topic = topicById.get(id);
    const graph = graphById.get(id);
    if (!topic || !graph) throw new Error(`Curriculum unit ${unit.id}: topic ${id} is incomplete`);
    return { ...topic, strand: graph.strand, group: graph.group, outcomes: graph.outcomes, deepens: graph.deepens, related: graph.related };
  }),
}));

// Every checkpoint the content owns; the Lernpfad shows each one's state (done,
// due, or "n lessons to go"). A new checkpoint YAML appears here by itself.
const checkpoints = (await getCheckpoints()).map(({ setId, level, path, title, items }) => ({
  setId,
  level,
  path,
  title,
  items,
}));
---

<Base title="Themen">
  <header>
    <h1 class="text-3xl font-bold tracking-tight"><Chrome k="nav.themen" /></h1>
    <p class="mt-1 text-stone-500 dark:text-stone-400">
      <span class="lang-en">Your course path — continue clearly, explore freely.</span>
      <span class="lang-ru">Ваш учебный путь: понятный следующий шаг и свободный выбор тем.</span>
    </p>
  </header>

  <div class="mt-6">
    <CurriculumPath client:load units={units} groups={curriculum.groups} spine={curriculum.spine} checkpoints={checkpoints} />
  </div>
</Base>
