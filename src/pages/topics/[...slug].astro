---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Bilingual from '../../components/Bilingual.astro';
import En from '../../components/En.astro';
import Ru from '../../components/Ru.astro';
import Uk from '../../components/Uk.astro';
import De from '../../components/De.astro';
import ExampleQuote from '../../components/ExampleQuote.astro';
import CaseTable from '../../components/reference/CaseTable.astro';
import PronominalAdverbTable from '../../components/reference/PronominalAdverbTable.astro';
import VocabTable from '../../components/VocabTable.astro';
import WordField from '../../components/vocab/WordField.astro';
import ExerciseSetIsland from '../../components/exercises/ExerciseSet';
import ReadingTextIsland from '../../components/reading/ReadingText';
import DueBadge from '../../components/srs/DueBadge';
import TopicProgress from '../../components/topic/TopicProgress';
import { KIND_LABEL } from '../../lib/content';
import { buildDeck, wordFieldContexts } from '../../lib/srs';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const topics = await getCollection('topics');
  return topics.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const wordFields = (await getCollection('wortfelder')).filter((field) => field.data.topic === data.id);
const lexicalContexts = wordFieldContexts(wordFields.map((field) => field.data));

const allTopics = await getCollection('topics');
const byId = new Map(allTopics.map((t) => [t.data.id, t]));
const prerequisites = data.prerequisites
  .map((id) => byId.get(id))
  .filter((t) => t !== undefined);

const exerciseSets = await Promise.all(
  data.exercises.map(async (id) => {
    const set = await getEntry('exercises', id);
    if (!set) throw new Error(`Topic ${data.id}: exercise set "${id}" not found`);
    const document = set.data.stimulus ? await getEntry('documents', set.data.stimulus) : undefined;
    if (set.data.stimulus && !document)
      throw new Error(`Topic ${data.id}: document "${set.data.stimulus}" not found`);
    return { id, data: set.data, document: document?.data };
  }),
);

const vocabFiles = await Promise.all(
  data.vocab.map(async (id) => {
    const v = await getEntry('vocab', id);
    if (!v) throw new Error(`Topic ${data.id}: vocab file "${id}" not found`);
    return v.data;
  }),
);

const readings = await Promise.all(
  data.reading.map(async (id) => {
    const r = await getEntry('reading', id);
    if (!r) throw new Error(`Topic ${data.id}: reading "${id}" not found`);
    return { id, data: r.data };
  }),
);

const pretestSet = data.pretest ? await getEntry('exercises', data.pretest) : undefined;
if (data.pretest && !pretestSet)
  throw new Error(`Topic ${data.id}: pretest set "${data.pretest}" not found`);
---

<Base title={data.title_de}>
  <nav class="mb-4 text-sm text-stone-400">
    <a href={withBase('/topics')} class="hover:text-stone-600 dark:hover:text-stone-200">Themen</a>
    <span> / {data.level}</span>
  </nav>

  <header class="mb-8">
    <div class="flex flex-wrap items-center gap-2 text-xs">
      <span class="rounded-full bg-amber-100 px-2.5 py-0.5 font-bold text-amber-800 dark:bg-amber-900 dark:text-amber-200">
        {data.level}
      </span>
      <span class="rounded-full bg-stone-200 px-2.5 py-0.5 font-medium text-stone-600 dark:bg-stone-700 dark:text-stone-300">
        {KIND_LABEL[data.kind]}
      </span>
      {data.status === 'draft' && (
        <span class="rounded-full border border-stone-300 px-2.5 py-0.5 text-stone-400 dark:border-stone-600">
          Entwurf
        </span>
      )}
      <TopicProgress
        client:only="react"
        topicId={data.id}
        exerciseSets={data.exercises}
        vocabIds={data.vocab}
        readingIds={data.reading}
        pretestId={data.pretest}
      />
    </div>
    <h1 lang="de" class="mt-3 text-3xl font-bold tracking-tight">{data.title_de}</h1>
    <p class="mt-1 text-stone-500 dark:text-stone-400">
      <span class="lang-en">{data.title_en}</span>
      <span class="lang-ru">{data.title_ru}</span>
      {data.title_uk && <span class="lang-uk">{data.title_uk}</span>}
    </p>
    {
      prerequisites.length > 0 && (
        <p class="mt-3 text-sm text-stone-500 dark:text-stone-400">
          Voraussetzungen:
          {prerequisites.map((p) => (
            <a
              href={withBase(`/topics/${p.id}`)}
              lang="de"
              class="ml-2 text-sky-700 hover:underline dark:text-sky-400"
            >
              {p.data.title_de}
            </a>
          ))}
        </p>
      )
    }
  </header>

  {
    data.pretest && pretestSet && (
      <aside class="mb-10 rounded-xl border-2 border-dashed border-amber-400 bg-amber-50/60 p-5 dark:border-amber-700 dark:bg-amber-950/40">
        <h2 lang="de" class="text-lg font-bold">Was weißt du schon?</h2>
        <p class="mt-1 mb-4 text-sm text-stone-600 dark:text-stone-400">
          <span class="lang-en">
            Try to answer before you read — guessing first, even wrongly, measurably improves what
            you remember from the article.
          </span>
          <span class="lang-ru">
            Попробуйте ответить до чтения: догадки заранее — даже неверные — заметно улучшают
            запоминание материала.
          </span>
        </p>
        <ExerciseSetIsland client:only="react" setId={data.pretest} set={pretestSet.data} />
      </aside>
    )
  }

  <article class="article-prose">
    <Content components={{ Bilingual, En, Ru, Uk, De, CaseTable, PronominalAdverbTable, blockquote: ExampleQuote }} />
  </article>

  {
    readings.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-4 text-2xl font-bold">Lesetext</h2>
        <div class="flex flex-col gap-6">
          {readings.map((r) => (
            <ReadingTextIsland client:only="react" readingId={r.id} reading={r.data} />
          ))}
        </div>
      </section>
    )
  }

  {
    wordFields.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-4 text-2xl font-bold">Wortfeld</h2>
        <div class="space-y-5">{wordFields.map((field) => <WordField field={field.data} />)}</div>
      </section>
    )
  }

  {
    vocabFiles.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-4 text-2xl font-bold">Wortschatz</h2>
        {vocabFiles.map((v) => (
          <div class="mb-8">
            <div class="mb-2 flex items-center gap-3">
              <h3 lang="de" class="text-lg font-semibold">{v.title_de}</h3>
              <DueBadge client:only="react" cards={buildDeck(v.id, v.entries, lexicalContexts)} />
              <a
                href={withBase(`/vocab/${v.id}`)}
                class="ml-auto text-sm font-medium text-amber-700 hover:underline dark:text-amber-400"
              >
                Karten lernen →
              </a>
            </div>
            <VocabTable entries={v.entries} />
          </div>
        ))}
      </section>
    )
  }

  {
    exerciseSets.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-4 text-2xl font-bold">Übungen</h2>
        <div class="flex flex-col gap-6">
          {exerciseSets.map((s) => (
            <ExerciseSetIsland client:only="react" setId={s.id} set={s.data} document={s.document} />
          ))}
        </div>
      </section>
    )
  }
</Base>
