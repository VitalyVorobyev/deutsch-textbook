---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Bilingual from '../../components/Bilingual.astro';
import Chrome from '../../components/Chrome.astro';
import En from '../../components/En.astro';
import Ru from '../../components/Ru.astro';
import Uk from '../../components/Uk.astro';
import De from '../../components/De.astro';
import ArtifactFeedback from '../../components/discovery/ArtifactFeedback';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  // Same gate as the index. `status` defaults to 'draft', so building the unfiltered
  // collection shipped unreviewed pieces live and crawlable — merely unlisted.
  const entries = await getCollection('discovery', ({ data }) => data.status === 'reviewed');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title_de}>
  <nav class="mb-5 text-sm text-stone-400"><a href={withBase('/entdecken')} class="hover:text-stone-700"><Chrome k="nav.entdecken" /></a> / {entry.data.level}</nav>
  <header><span class="text-xs font-bold text-amber-700">{entry.data.level} · <Chrome k="nav.entdecken" /></span><h1 lang="de" class="mt-2 text-3xl font-bold">{entry.data.title_de}</h1><p class="mt-1 text-stone-500"><span class="lang-en">{entry.data.title_en}</span><span class="lang-ru">{entry.data.title_ru}</span>{entry.data.title_uk && <span class="lang-uk">{entry.data.title_uk}</span>}</p></header>
  {entry.data.images.map((image) => (
    <figure class="mt-7">
      <a href={withBase(image.src)} target="_blank" rel="noreferrer"><img src={withBase(image.src)} alt={image.alt} class="w-full rounded-xl border border-stone-200 dark:border-stone-700" /></a>
      {image.attribution && <figcaption class="mt-1 text-xs text-stone-400">{image.attribution}{image.license && ` · ${image.license}`}</figcaption>}
    </figure>
  ))}
  <article class="article-prose mt-8"><Content components={{ Bilingual, En, Ru, Uk, De }} /></article>
  {entry.data.links.length > 0 && (
    <section class="mt-10 rounded-xl border border-stone-200 p-5 dark:border-stone-700">
      <h2 class="text-lg font-bold"><Chrome k="discovery.links" /></h2>
      <p class="mt-1 text-sm text-stone-400"><span class="lang-en">External material, online only — nothing in the course depends on it.</span><span class="lang-ru">Внешние материалы, только онлайн — ничто в курсе от них не зависит.</span></p>
      <ul class="mt-3 space-y-2">
        {entry.data.links.map((link) => (
          <li>
            <a href={link.url} target="_blank" rel="noreferrer" class="font-medium text-amber-700 hover:underline">{link.label} ↗</a>
            {link.note && <span class="ml-2 text-sm text-stone-500"><span class="lang-en">{link.note.en}</span><span class="lang-ru">{link.note.ru}</span>{link.note.uk && <span class="lang-uk">{link.note.uk}</span>}{link.note.de && <span class="lang-de">{link.note.de}</span>}</span>}
          </li>
        ))}
      </ul>
    </section>
  )}
  <ArtifactFeedback client:only="react" artifactId={`discovery:${entry.id}`} />
</Base>
