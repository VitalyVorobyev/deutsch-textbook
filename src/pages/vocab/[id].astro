---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import VocabTable from '../../components/VocabTable.astro';
import FlashcardSession from '../../components/srs/FlashcardSession';
import { buildDeck } from '../../lib/srs';

export async function getStaticPaths() {
  const vocab = await getCollection('vocab');
  return vocab.map((entry) => ({ params: { id: entry.data.id }, props: { entry } }));
}

const { entry } = Astro.props;
const data = entry.data;
const cards = buildDeck(data.id, data.entries);
---

<Base title={data.title_de}>
  <nav class="mb-4 text-sm text-stone-400">
    <a href="/vocab" class="hover:text-stone-600 dark:hover:text-stone-200">Wortschatz</a>
  </nav>

  <header class="mb-8">
    <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-bold text-amber-800 dark:bg-amber-900 dark:text-amber-200">
      {data.level}
    </span>
    <h1 lang="de" class="mt-3 text-3xl font-bold tracking-tight">{data.title_de}</h1>
    <p class="mt-1 text-stone-500 dark:text-stone-400">
      <span class="lang-en">{data.title_en}</span>
      <span class="lang-ru">{data.title_ru}</span>
    </p>
  </header>

  <FlashcardSession client:only="react" cards={cards} />

  <section class="mt-12">
    <h2 class="mb-4 text-2xl font-bold">Alle Wörter</h2>
    <VocabTable entries={data.entries} />
  </section>
</Base>
