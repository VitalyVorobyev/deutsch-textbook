---
import Base from '../../layouts/Base.astro';
import UebenNav from '../../components/UebenNav.astro';
import FlashcardSession from '../../components/srs/FlashcardSession';
import { getAllCards, getDeckLevels, getTopicNodes } from '../../lib/content';

const [cards, nodes, deckLevels] = await Promise.all([
  getAllCards(),
  getTopicNodes(),
  getDeckLevels(),
]);
---

<Base title="Wiederholen">
  <UebenNav active="wiederholen" />
  <h1 class="text-3xl font-bold tracking-tight">Wiederholen</h1>
  <p class="mt-1 text-stone-500 dark:text-stone-400">
    <span class="lang-en">Your daily review across all decks — due cards first, then a few new ones.</span>
    <span class="lang-ru">Ежедневное повторение по всем колодам — сначала карточки к повторению, затем немного новых.</span>
  </p>

  <div class="mt-8">
    <FlashcardSession client:only="react" cards={cards} newLimit={15} gate={{ nodes, deckLevels }} />
  </div>
</Base>
