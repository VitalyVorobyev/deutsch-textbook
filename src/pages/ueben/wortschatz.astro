---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Chrome from '../../components/Chrome.astro';
import UebenNav from '../../components/UebenNav.astro';
import DueBadge from '../../components/srs/DueBadge';
import { buildDeck, wordFieldContexts } from '../../lib/srs';
import { t } from '../../lib/strings';
import { withBase } from '../../lib/url';
import { DeckMasterySummary } from '../../components/vocab/VocabMastery';

const [vocab, fields] = await Promise.all([getCollection('vocab'), getCollection('wortfelder')]);
const lexicalContexts = wordFieldContexts(fields.map((field) => field.data));
const decks = vocab
  .map((v) => ({ data: v.data, cards: buildDeck(v.data.id, v.data.entries, lexicalContexts) }))
  .sort((a, b) => a.data.level.localeCompare(b.data.level) || a.data.title_de.localeCompare(b.data.title_de, 'de'));
---

<Base title="Wortschatz">
  <UebenNav active="wortschatz" />
  <h1 class="text-3xl font-bold tracking-tight"><Chrome k="ueben.tabWortschatz" /></h1>
  <p class="mt-1 text-stone-500 dark:text-stone-400">
    <span class="lang-en">Flashcard decks built from the vocabulary base.</span>
    <span class="lang-ru">Колоды карточек, собранные из словарной базы.</span>
  </p>

  <div class="mt-8 grid gap-3 sm:grid-cols-2">
    {
      decks.map(({ data, cards }) => (
        <a
          href={withBase(`/vocab/${data.id}`)}
          class="rounded-lg border border-stone-200 bg-white p-4 hover:border-amber-400 dark:border-stone-700 dark:bg-stone-800 dark:hover:border-amber-500"
        >
          <div class="flex items-center gap-2">
            <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-bold text-amber-800 dark:bg-amber-900 dark:text-amber-200">
              {data.level}
            </span>
            <DueBadge client:only="react" cards={cards} />
          </div>
          <p lang="de" class="mt-2 font-semibold">{data.title_de}</p>
          <p class="mt-0.5 text-sm text-stone-500 dark:text-stone-400">
            <span class="lang-en">{data.title_en}</span>
            <span class="lang-ru">{data.title_ru}</span>
            {data.title_uk && <span class="lang-uk">{data.title_uk}</span>}
          </p>
          <p class="mt-2 text-xs text-stone-400">
            {t('vocab.deckSize', 'de')
              .replace('{words}', String(data.entries.length))
              .replace('{cards}', String(cards.length))}
          </p>
          <DeckMasterySummary client:only="react" cards={cards} />
        </a>
      ))
    }
  </div>
</Base>
