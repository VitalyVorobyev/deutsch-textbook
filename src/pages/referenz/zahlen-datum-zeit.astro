---
import { getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { withBase } from '../../lib/url';
import { zahlenDatumZeitReferenceSchema } from '../../lib/schemas';

const entry = await getEntry('referenceData', 'zahlen-datum-zeit');
if (!entry) throw new Error('Missing canonical zahlen-datum-zeit reference data');
const data = zahlenDatumZeitReferenceSchema.parse(entry.data);
---

<Base title="Zahlen, Datum & Zeit">
  <nav class="mb-5 text-sm text-stone-400"><a href={withBase('/referenz')} class="hover:text-stone-700">Referenz</a> / Zahlen, Datum & Zeit</nav>
  <header>
    <span class="text-xs font-bold uppercase tracking-wide text-amber-700">Nachschlagen · kein Lernstatus</span>
    <h1 class="mt-2 text-3xl font-bold">Zahlen, Datum &amp; Zeit</h1>
    <p class="mt-2 max-w-2xl text-stone-500">
      <span class="lang-en">Numbers, ordinals, the clock and the calendar in one place. The lessons teach each part; this page just puts the forms next to each other.</span>
      <span class="lang-ru">Числа, порядковые числительные, время и календарь в одном месте. Уроки объясняют части по отдельности; здесь формы просто собраны рядом.</span>
      <span class="lang-uk">Числа, порядкові числівники, час і календар в одному місці. Уроки пояснюють частини окремо; тут форми просто зібрані поряд.</span>
    </p>
  </header>

  <section class="mt-10">
    <h2 class="mb-4 text-2xl font-bold">Kardinalzahlen</h2>
    <div class="grid grid-cols-2 gap-x-6 gap-y-1 sm:grid-cols-3 md:grid-cols-4">
      {data.cardinals.map((n) => (
        <div class="flex items-baseline gap-2 border-b border-stone-100 py-1 dark:border-stone-800">
          <span class="w-14 shrink-0 text-right tabular-nums text-stone-400">{n.value}</span>
          <span lang="de" class="font-medium">{n.word}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="mb-4 text-2xl font-bold">Ordinalzahlen</h2>
    <div class="grid grid-cols-2 gap-x-6 gap-y-1 sm:grid-cols-3 md:grid-cols-4">
      {data.ordinals.map((n) => (
        <div class="flex items-baseline gap-2 border-b border-stone-100 py-1 dark:border-stone-800">
          <span class="w-14 shrink-0 text-right tabular-nums text-stone-400">{n.value}</span>
          <span lang="de" class="font-medium">{n.word}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="mb-4 text-2xl font-bold">Uhrzeit</h2>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[30rem] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-stone-300 text-left dark:border-stone-600">
            <th class="py-2 pr-4 font-semibold">Uhr</th>
            <th class="py-2 pr-4 font-semibold">Formell (24 h)</th>
            <th class="py-2 font-semibold">Umgangssprachlich</th>
          </tr>
        </thead>
        <tbody>
          {data.clock.map((c) => (
            <tr class="border-b border-stone-100 dark:border-stone-800">
              <td class="py-2 pr-4 tabular-nums text-stone-400">{c.time}</td>
              <td class="py-2 pr-4" lang="de">{c.formal}</td>
              <td class="py-2" lang="de">{c.colloquial ?? '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10 grid gap-6 sm:grid-cols-2">
    <div>
      <h2 class="mb-3 text-2xl font-bold">Wochentage</h2>
      <p lang="de" class="leading-relaxed">{data.weekdays.join(' · ')}</p>
    </div>
    <div>
      <h2 class="mb-3 text-2xl font-bold">Monate</h2>
      <p lang="de" class="leading-relaxed">{data.months.join(' · ')}</p>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="mb-4 text-2xl font-bold">Regeln</h2>
    <div class="grid gap-4">
      {data.notes.map((note) => (
        <article class="rounded-lg border border-stone-200 p-5 dark:border-stone-700">
          <h3 class="font-semibold">
            <span class="lang-en">{note.heading.en}</span>
            <span class="lang-ru">{note.heading.ru}</span>
            {note.heading.uk && <span class="lang-uk">{note.heading.uk}</span>}
          </h3>
          <p class="mt-2 text-sm">
            <span class="lang-en">{note.body.en}</span>
            <span class="lang-ru">{note.body.ru}</span>
            {note.body.uk && <span class="lang-uk">{note.body.uk}</span>}
          </p>
          {note.example && <p lang="de" class="mt-3 border-l-2 border-amber-400 pl-3 text-sm italic">{note.example.de}</p>}
        </article>
      ))}
    </div>
  </section>

  <section class="mt-10 rounded-lg border-l-4 border-amber-500 bg-amber-50 p-5 dark:bg-amber-950/25">
    <p>
      <span class="lang-en">Looking a form up is support, not evidence. To check whether you can produce it yourself, go back to a flashcard or a translation exercise.</span>
      <span class="lang-ru">Справочник — это поддержка, а не доказательство знания. Чтобы проверить, что вы можете образовать форму сами, вернитесь к карточке или упражнению на перевод.</span>
      <span class="lang-uk">Довідник — це підтримка, а не доказ знання. Щоб перевірити, що ви можете утворити форму самі, поверніться до картки або вправи на переклад.</span>
    </p>
  </section>
</Base>
