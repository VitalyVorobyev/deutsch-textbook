---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../lib/url';
---

<Base title="Referenz">
  <h1 class="text-3xl font-bold tracking-tight">Referenz</h1>
  <p class="mt-2 text-stone-500"><span class="lang-en">Compact lookup pages. Opening them does not change mastery or progress.</span><span class="lang-ru">Краткие справочные страницы. Их просмотр не влияет на освоение тем и прогресс.</span></p>
  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <a href={withBase('/referenz/kasus-praepositionen')} class="rounded-xl border border-stone-200 bg-white p-5 hover:border-amber-500 dark:border-stone-700 dark:bg-stone-800"><h2 class="text-lg font-semibold">Kasus & Präpositionen</h2><p class="mt-1 text-sm text-stone-500"><span class="lang-en">Articles, pronouns, and case-governing prepositions.</span><span class="lang-ru">Артикли, местоимения и управление падежами.</span></p></a>
    <a href={withBase('/referenz/da-wo-woerter')} class="rounded-xl border border-stone-200 bg-white p-5 hover:border-amber-500 dark:border-stone-700 dark:bg-stone-800"><h2 class="text-lg font-semibold">Da- & Wo-Wörter</h2><p class="mt-1 text-sm text-stone-500"><span class="lang-en">Questions about things, references back, and person alternatives.</span><span class="lang-ru">Вопросы о предметах, отсылки и формы для людей.</span></p></a>
  </div>
</Base>
