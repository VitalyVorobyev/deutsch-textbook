---
import Base from '../layouts/Base.astro';
import ProgressPanel from '../components/progress/ProgressPanel';
import { getCheckpoints, getTopicNodes } from '../lib/content';
import { getCurriculum } from '../lib/curriculum';
import { getAllCards } from '../lib/content';
import { getCollection } from 'astro:content';
import { probeFamilies } from '../lib/probes';

const nodes = await getTopicNodes();
const cards = await getAllCards();
const vocab = await getCollection('vocab');
const cardsByDeck = new Map<string, string[]>();
for (const card of cards) cardsByDeck.set(card.deckId, [...(cardsByDeck.get(card.deckId) ?? []), card.id]);
const vocabularyGroups = [
  {
    title: 'Niveau',
    items: ['A1', 'A2'].map((level) => ({
      id: level, label: level,
      cardIds: vocab.filter((deck) => deck.data.level === level).flatMap((deck) => cardsByDeck.get(deck.data.id) ?? []),
    })),
  },
  {
    title: 'Thema',
    items: vocab.map((deck) => ({ id: deck.data.id, label: deck.data.title_de, cardIds: cardsByDeck.get(deck.data.id) ?? [] })),
  },
  {
    title: 'Wortart',
    items: [...new Set(cards.map((card) => card.pos))].sort().map((pos) => ({ id: pos, label: pos, cardIds: cards.filter((card) => card.pos === pos).map((card) => card.id) })),
  },
];
const curriculum = getCurriculum();
const outcomeModes = Object.fromEntries(
  curriculum.nodes.flatMap((node) => node.outcomes.map((outcome) => [outcome.id, outcome.mode])),
);
const exercises = await getCollection('exercises');
const families = probeFamilies(
  exercises.map((e) => ({
    setId: e.id,
    topicId: e.data.topic,
    role: e.data.role,
    items: e.data.items.map((i) => ({ id: i.id, outcomes: i.outcomes })),
  })),
);
const titleByTopic = new Map(nodes.map((n) => [n.id, n.title_de]));
const probeLabels = Object.fromEntries(
  families.map((f) => [f.setId, titleByTopic.get(f.topicId) ?? f.topicId]),
);
const probeTopicPaths = Object.fromEntries(nodes.map((node) => [node.id, node.path]));
// One results panel per checkpoint in the content; each renders nothing until it
// has been taken, so a level whose checkpoint is untouched stays silent.
const checkpoints = (await getCheckpoints()).map(({ setId, title, path, items }) => ({
  setId,
  title,
  path,
  items,
}));
// All four halves travel: uk is the optional translation, and the outcome's
// `de` is the German can-do itself — exactly what 'de' mode should show.
const outcomeLabels = Object.fromEntries(
  curriculum.nodes.flatMap((node) =>
    node.outcomes.map((outcome) => [
      outcome.id,
      { en: outcome.en, ru: outcome.ru, uk: outcome.uk, de: outcome.de },
    ]),
  ),
);
---

<Base title="Fortschritt">
  <h1 class="text-3xl font-bold tracking-tight">Fortschritt</h1>
  <p class="mt-1 text-stone-500 dark:text-stone-400">
    <span class="lang-en">
      Your activity, streak, per-topic progress, and weak spots for the active profile — all stored
      in this browser. Export writes a snapshot to <code>progress/&lt;profile&gt;/</code> (or downloads
      it) so the agent can generate drills targeting your mistakes.
    </span>
    <span class="lang-ru">
      Активность, серия, прогресс по темам и слабые места активного профиля — всё хранится в этом
      браузере. Экспорт записывает снимок в <code>progress/&lt;profile&gt;/</code> (или скачивает его),
      чтобы агент создал упражнения по вашим ошибкам.
    </span>
  </p>

  <div class="mt-8">
    <ProgressPanel client:only="react" nodes={nodes} outcomeModes={outcomeModes} cards={cards} vocabularyGroups={vocabularyGroups} checkpoints={checkpoints} outcomeLabels={outcomeLabels} probeFamilies={families} probeLabels={probeLabels} probeTopicPaths={probeTopicPaths} />
  </div>
</Base>
