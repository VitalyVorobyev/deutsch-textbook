---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Chrome from '../components/Chrome.astro';
import { getCheckpoints } from '../lib/content';
import { getCurriculum } from '../lib/curriculum';
import { goetheCoverage, hasManifest, ukTranslationCoverage } from '../lib/coverage';
import { grammarCoverage } from '../lib/grammar-coverage';
import { withBase } from '../lib/url';

const REPO = 'https://github.com/VitalyVorobyev/deutsch-textbook';

// Every figure on this page is measured from the content at build time. Nothing
// here is a hand-maintained claim that can quietly go stale.
const [topics, exercises, readings, vocab] = await Promise.all([
  getCollection('topics'),
  getCollection('exercises'),
  getCollection('reading'),
  getCollection('vocab'),
]);
const { units } = getCurriculum();
const coverage = goetheCoverage('A1');
// A level with no committed Wortliste manifest has no coverage figure, and must not
// invent one. A2 gets its sentence only once data/goethe-a2-wortliste.txt exists.
const coverageA2 = hasManifest('A2') ? goetheCoverage('A2') : null;
// B1 has a manifest but no units: the figure below measures how much of the B1
// Wortliste the A1/A2 decks already teach — a claim about the learner's lexis,
// never about B1 completeness.
const coverageB1 = hasManifest('B1') ? goetheCoverage('B1') : null;
// The structural counterpart to the Wortliste figure, and it exists because the lexical
// one was carrying the whole claim: A2 was called content-complete for months on the
// strength of 100% vocabulary while six A2-standard structures were unwritten. Computed
// from the content at build time, like every other number on this page.
const grammarA1 = grammarCoverage('A1');
const grammarA2 = grammarCoverage('A2');
// The Ukrainian-translation figure, same earned-claims rule: measured from the
// content files at build time, never hand-written — and 0 is stated as 0.
const ukCoverage = ukTranslationCoverage();

const levels = ['A1', 'A2'] as const;
const stats = levels.map((level) => {
  const words = new Set(
    vocab.filter((deck) => deck.data.level === level).flatMap((deck) => deck.data.entries.map((e) => e.de)),
  );
  return {
    level,
    topics: topics.filter((t) => t.data.level === level).length,
    units: units.filter((u) => u.level === level).length,
    words: words.size,
  };
});
const a1 = stats.find((s) => s.level === 'A1')!;
const a2 = stats.find((s) => s.level === 'A2')!;
// Checkpoints are content, so the claims below are too: whether a level has one
// at all, and how big it is, are both read off the checkpoint sets.
const checkpoints = await getCheckpoints();
const checkpointA1 = checkpoints.find((c) => c.level === 'A1');
const checkpointA2 = checkpoints.find((c) => c.level === 'A2');

const principles = [
  {
    de: 'Aktives Abrufen',
    en: 'Retrieval, not re-reading. Every exercise makes you produce the answer — you type the German rather than pick it from a list wherever typing is possible. Pulling a word out of memory is what strengthens it; recognising it on a page barely does.',
    ru: 'Активное припоминание, а не перечитывание. Каждое упражнение требует произвести ответ: там, где это возможно, немецкое слово вы печатаете, а не выбираете из списка. Память укрепляет именно извлечение слова, а не его узнавание на странице.',
  },
  {
    de: 'Verteiltes Wiederholen',
    en: 'Spacing over cramming. Flashcards are scheduled by FSRS, a modern spaced-repetition algorithm, so a word comes back close to the moment you would have forgotten it. For the same reason a topic only counts as mastered once your practice spans at least two different days.',
    ru: 'Интервальное повторение вместо зубрёжки. Карточки планирует FSRS — современный алгоритм интервальных повторений, — поэтому слово возвращается примерно тогда, когда вы уже готовы его забыть. По той же причине тема считается освоенной, только если практика заняла не менее двух разных дней.',
  },
  {
    de: 'Verschränktes Üben',
    en: 'Interleaving. Mixed training deliberately shuffles topics instead of drilling one to exhaustion — blocked practice feels smoother and teaches less, because it lets you apply a rule without first having to choose it.',
    ru: 'Чередование тем. Смешанная тренировка намеренно перемешивает темы вместо того, чтобы «добивать» одну: блочная практика ощущается легче, но учит меньше — она позволяет применить правило, не выбирая его.',
  },
  {
    de: 'Erst raten, dann lernen',
    en: 'Guess first, then learn. Each topic opens with a short pretest you are expected to get wrong. Trying and failing before an explanation measurably improves what the explanation then sticks to — so a pretest is never scored against you.',
    ru: 'Сначала попытка, потом объяснение. Каждая тема начинается с короткого претеста, в котором ошибаться нормально. Неудачная попытка до объяснения заметно улучшает усвоение самого объяснения — поэтому претест никогда не идёт в зачёт.',
  },
  {
    de: 'Erklärendes Feedback',
    en: 'A wrong answer teaches. Instead of a red cross, you get the rule you tripped over — in English or in Russian, right where you tripped. Every error you make is also tagged with the confusion behind it, and those tags are what steer your future practice.',
    ru: 'Ошибка учит. Вместо красного крестика появляется правило, на котором вы споткнулись, — по-английски или по-русски, прямо на месте ошибки. Каждая ошибка помечается стоящей за ней путаницей, и именно эти метки направляют вашу дальнейшую практику.',
  },
  {
    de: 'Verständlicher Input',
    en: 'Comprehensible input. Every topic carries a reading written at its own level, with the hard phrases glossed in place. Language is not only assembled from rules — a good deal of it is absorbed from text you can almost, but not quite, read effortlessly.',
    ru: 'Понятный ввод. У каждой темы есть текст для чтения, написанный на её уровне, со сносками к трудным местам. Язык не только собирается из правил — во многом он усваивается из текста, который вы почти, но не совсем, читаете без усилий.',
  },
  {
    de: 'Ehrliche Messung',
    en: 'Honest measurement. Free writing is saved as practice and never quietly counted as a correct answer, because nothing here can actually check it. Your mastery badge reflects what was really measured — you can tell the app you have learned something, and it will move you along without pretending that was evidence.',
    ru: 'Честное измерение. Свободное письмо сохраняется как практика и никогда не засчитывается как верный ответ: проверить его тут по-настоящему нечем. Значок освоения отражает только то, что действительно измерено. Вы можете отметить тему как выученную — приложение пойдёт дальше, но не станет выдавать это за доказательство.',
  },
  {
    de: 'Kein Spielkram',
    en: 'No gamification. No streak you must not break, no coins, no leaderboard, no notifications. The dashboard exists to show you where you actually stand, not to manufacture a reason to come back.',
    ru: 'Никакой геймификации. Ни серии, которую нельзя прервать, ни монет, ни таблиц лидеров, ни уведомлений. Панель прогресса нужна, чтобы показать реальное положение дел, а не чтобы придумать повод вернуться.',
  },
];
---

<Base title="Über Deutsch-Atlas">
  <h1 class="text-3xl font-bold tracking-tight"><Chrome k="about.pageTitle" /></h1>
  <p class="mt-2 max-w-prose text-stone-500 dark:text-stone-400">
    <span class="lang-en">
      A free, local-first German course: a textbook, interactive exercises and spaced-repetition
      flashcards in one place. Every explanation is written twice — in English and in Russian —
      while the German itself stays German.
    </span>
    <span class="lang-ru">
      Бесплатный курс немецкого, работающий локально: учебник, интерактивные упражнения и карточки
      с интервальным повторением в одном месте. Каждое объяснение написано дважды — по-английски и
      по-русски, — а сам немецкий остаётся немецким.
    </span>
  </p>

  <section class="mt-10">
    <h2 class="text-xl font-bold">
      <span class="lang-en">How this course teaches</span>
      <span class="lang-ru">Как устроено обучение</span>
    </h2>
    <p class="mt-2 max-w-prose text-sm text-stone-500 dark:text-stone-400">
      <span class="lang-en">
        The design follows what research on learning actually supports, not what feels productive.
        Several of these principles are deliberately uncomfortable: they make a session feel harder
        while making the results last longer.
      </span>
      <span class="lang-ru">
        В основе — то, что действительно подтверждается исследованиями об обучении, а не то, что
        просто кажется продуктивным. Некоторые из этих принципов намеренно неудобны: занятие
        становится труднее, зато результат держится дольше.
      </span>
    </p>

    <dl class="mt-6 grid gap-5 sm:grid-cols-2">
      {principles.map((p) => (
        <div class="rounded-lg border border-stone-200 bg-white p-5 dark:border-stone-700 dark:bg-stone-800">
          <dt lang="de" class="font-semibold">{p.de}</dt>
          <dd class="mt-2 text-sm text-stone-600 dark:text-stone-300">
            <span class="lang-en">{p.en}</span>
            <span class="lang-ru">{p.ru}</span>
          </dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-bold">
      <span class="lang-en">How complete the course is</span>
      <span class="lang-ru">Насколько курс завершён</span>
    </h2>
    <p class="mt-2 max-w-prose text-sm text-stone-500 dark:text-stone-400">
      <span class="lang-en">
        An honest answer, because a half-finished level is worse than a missing one — you would
        study it believing it covered the ground. These numbers are measured from the course
        content each time this page is built.
      </span>
      <span class="lang-ru">
        Честный ответ, потому что наполовину готовый уровень хуже отсутствующего: его проходят в
        уверенности, что материал охвачен. Все числа измеряются по содержанию курса при каждой
        сборке этой страницы.
      </span>
    </p>

    <div class="mt-6 space-y-4">
      <article class="rounded-lg border-l-4 border-emerald-500 bg-emerald-50/60 p-5 dark:bg-emerald-950/25">
        <h3 class="font-bold">
          A1 — <span class="lang-en">complete</span><span class="lang-ru">завершён</span>
        </h3>
        <p class="mt-2 max-w-prose text-sm text-stone-700 dark:text-stone-300">
          <span class="lang-en">
            All {a1.units} units are authored, from Erste Schritte to Freizeit &amp; Können. Each one
            has a diagnostic pretest, a full article, a graded reading, exercises across several task
            types, and its own vocabulary. {coverage.cards + coverage.grammar} of the
            {' '}{coverage.total} headwords on the official Goethe-Institut A1 Wortliste are covered
            ({coverage.percent}%) — {coverage.cards} as flashcards and {coverage.grammar} taught as
            grammar rather than as vocabulary. All {grammarA1.total} grammar points the A1 standard
            expects are taught, {grammarA1.late} of them at A2 — a sequencing choice this course
            makes deliberately and does not hide. A cumulative
            {checkpointA1 && ` ${checkpointA1.items.length}-item`} A1 checkpoint measures the
            level end to end.
          </span>
          <span class="lang-ru">
            Все {a1.units} юнитов написаны — от «Erste Schritte» до «Freizeit &amp; Können». В каждом
            есть диагностический претест, полная статья, текст для чтения, упражнения нескольких
            типов и собственный словарь. Из {coverage.total} слов официального списка Goethe-Institut
            A1 Wortliste охвачено {coverage.cards + coverage.grammar} ({coverage.percent}%):
            {' '}{coverage.cards} — карточками, ещё {coverage.grammar} даются как грамматика, а не как
            лексика. Все {grammarA1.total} грамматических пунктов стандарта A1 охвачены, {grammarA1.late}
            из них даются на A2 — это осознанный выбор последовательности, и он не скрывается.
            Итоговая контрольная точка A1
            {checkpointA1 && ` из ${checkpointA1.items.length} заданий`} проверяет уровень
            целиком.
          </span>
        </p>
      </article>

      <article class="rounded-lg border-l-4 border-emerald-500 bg-emerald-50/60 p-5 dark:bg-emerald-950/25">
        <h3 class="font-bold">
          A2 — <span class="lang-en">complete</span><span class="lang-ru">завершён</span>
        </h3>
        <p class="mt-2 max-w-prose text-sm text-stone-700 dark:text-stone-300">
          <span class="lang-en">
            All {a2.units} units are authored, from Dativ to Ämter &amp; Dienstleistungen. Each one has
            a diagnostic pretest, a full article, a graded reading, exercises across several task
            types including listening, writing and speaking, and a delayed probe that asks the same
            competence again weeks later.
            {coverageA2 &&
              ` ${coverageA2.cards + coverageA2.grammar} of the ${coverageA2.total} headwords on the
              official Goethe-Institut A2 Wortliste are covered (${coverageA2.percent}%) —
              ${coverageA2.cards} as flashcards and ${coverageA2.grammar} taught as grammar rather
              than as vocabulary.`}
            {` All ${grammarA2.total} grammar points the A2 standard expects are taught
              (${grammarA2.percent}%), each one measured by a practice or drill item that names the
              confusion it drills — testing a structure in a checkpoint does not count as teaching it.`}
            {checkpointA2 && ` A cumulative ${checkpointA2.items.length}-item A2 checkpoint measures
              the level end to end.`} What that does not mean is that finishing it makes you A2 —
            that is a claim about you, not about the content, and no course can make it for you.
          </span>
          <span class="lang-ru">
            Все {a2.units} юнитов написаны — от «Dativ» до «Ämter &amp; Dienstleistungen». В каждом есть
            диагностический претест, полная статья, текст для чтения, упражнения нескольких типов —
            включая аудирование, письмо и говорение — и отложенная проверка, которая спрашивает то же
            умение снова спустя недели.
            {coverageA2 &&
              ` Из ${coverageA2.total} слов официального списка Goethe-Institut A2 Wortliste охвачено
              ${coverageA2.cards + coverageA2.grammar} (${coverageA2.percent}%): ${coverageA2.cards} —
              карточками, ещё ${coverageA2.grammar} даются как грамматика, а не как лексика.`}
            {` Все ${grammarA2.total} грамматических пунктов стандарта A2 охвачены (${grammarA2.percent}%),
              и каждый подтверждён упражнением, которое называет соответствующую трудность:
              проверить структуру в контрольной точке не значит её обучить.`}
            {checkpointA2 && ` Итоговая контрольная точка A2 из ${checkpointA2.items.length} заданий
              проверяет уровень целиком.`} Это не значит, что, пройдя курс, вы автоматически получите
            A2: это утверждение о вас, а не о содержании, и ни один курс не может сделать его за вас.
          </span>
        </p>
      </article>

      <article class="rounded-lg border-l-4 border-stone-300 p-5 dark:border-stone-600">
        <h3 class="font-bold">
          B1 <span class="lang-en">and beyond — not started</span
          ><span class="lang-ru">и выше — не начато</span>
        </h3>
        <p class="mt-2 max-w-prose text-sm text-stone-600 dark:text-stone-400">
          <span class="lang-en">
            Nothing above A2 exists yet. The long-term aim is B2, and the course is built so that
            levels can be added without disturbing what you have already learned.
            {coverageB1 &&
              ` ${coverageB1.cards + coverageB1.grammar} of the ${coverageB1.total} headwords on the
              official Goethe-Institut B1 Wortliste are already covered by A1/A2 material
              (${coverageB1.percent}%) — a head start on the level's vocabulary, not progress on the
              level itself.`}
          </span>
          <span class="lang-ru">
            Выше A2 пока ничего нет. Долгосрочная цель — B2, и курс построен так, чтобы новые уровни
            добавлялись, не затрагивая уже пройденное.
            {coverageB1 &&
              ` Из ${coverageB1.total} слов официального списка Goethe-Institut B1 Wortliste
              ${coverageB1.cards + coverageB1.grammar} (${coverageB1.percent}%) уже охвачены
              материалами A1–A2 — это задел по лексике уровня, а не прогресс по самому уровню.`}
          </span>
        </p>
      </article>
    </div>

    <p class="mt-4 max-w-prose text-sm text-stone-500 dark:text-stone-400">
      <span class="lang-en">
        Explanations are written in English and Russian throughout; a Ukrainian translation is
        arriving in waves and is measured like everything on this page — {ukCoverage.translated} of
        {' '}{ukCoverage.total} content files carry the Ukrainian half so far, and where it is
        missing the app shows English.
      </span>
      <span class="lang-ru">
        Пояснения написаны на английском и русском по всему курсу; украинский перевод выходит
        волнами и измеряется так же, как всё на этой странице, — украинская половина пока есть в
        {' '}{ukCoverage.translated} из {ukCoverage.total} файлов контента, а там, где её нет,
        показывается английский.
      </span>
    </p>

    <dl class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      {[
        ['Themen', String(topics.length)],
        ['Übungssätze', String(exercises.length)],
        ['Lesetexte', String(readings.length)],
        ['Wörter', `${a1.words + a2.words}`],
      ].map(([label, value]) => (
        <div class="rounded-lg border border-stone-200 bg-white p-4 text-center dark:border-stone-700 dark:bg-stone-800">
          <dt lang="de" class="text-xs uppercase tracking-wide text-stone-400">{label}</dt>
          <dd class="mt-1 text-2xl font-bold">{value}</dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-bold">
      <span class="lang-en">Your data</span>
      <span class="lang-ru">Ваши данные</span>
    </h2>
    <p class="mt-2 max-w-prose text-sm text-stone-600 dark:text-stone-300">
      <span class="lang-en">
        There is no account and no server. Your answers and your flashcard schedule live in this
        browser (or in the desktop app's own storage), and several people can share one device with
        fully separate progress. The <a href={withBase('/progress')} class="font-medium text-amber-700 hover:underline dark:text-amber-400">Fortschritt</a>
        {' '}page can export everything as a JSON file and import it elsewhere.
      </span>
      <span class="lang-ru">
        Здесь нет ни аккаунта, ни сервера. Ваши ответы и расписание карточек хранятся в этом браузере
        (или в собственном хранилище настольного приложения), а одним устройством могут пользоваться
        несколько человек с полностью раздельным прогрессом. На странице
        {' '}<a href={withBase('/progress')} class="font-medium text-amber-700 hover:underline dark:text-amber-400">Fortschritt</a>
        {' '}всё можно выгрузить в JSON-файл и загрузить в другом месте.
      </span>
    </p>
  </section>

  <section class="mt-12 rounded-lg border border-stone-200 bg-white p-6 dark:border-stone-700 dark:bg-stone-800">
    <h2 class="text-xl font-bold">
      <span class="lang-en">Open source</span>
      <span class="lang-ru">Открытый исходный код</span>
    </h2>
    <p class="mt-2 max-w-prose text-sm text-stone-600 dark:text-stone-300">
      <span class="lang-en">
        The whole project — every article, exercise, reading and word list, and the app that renders
        them — is public. If something here is wrong, you can see exactly how it was written and say
        so.
      </span>
      <span class="lang-ru">
        Весь проект — каждая статья, упражнение, текст и список слов, а также приложение, которое их
        отображает, — открыт. Если здесь что-то неверно, вы можете увидеть, как именно это написано,
        и сообщить об ошибке.
      </span>
    </p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a
        href={REPO}
        rel="noopener noreferrer"
        target="_blank"
        class="rounded-md bg-stone-800 px-4 py-2 text-sm font-semibold text-white hover:bg-stone-700 dark:bg-stone-100 dark:text-stone-900 dark:hover:bg-white"
      >
        <span class="lang-en">View the project on GitHub →</span>
        <span class="lang-ru">Проект на GitHub →</span>
      </a>
      <a
        href={`${REPO}/issues`}
        rel="noopener noreferrer"
        target="_blank"
        class="rounded-md border border-stone-300 px-4 py-2 text-sm font-semibold hover:border-amber-500 dark:border-stone-600"
      >
        <span class="lang-en">Report a mistake</span>
        <span class="lang-ru">Сообщить об ошибке</span>
      </a>
    </div>
  </section>
</Base>
