---
import { getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ExerciseSetIsland from '../../components/exercises/ExerciseSet';
import { withBase } from '../../lib/url';

const set = await getEntry('exercises', 'a1/checkpoint-a1');
if (!set) throw new Error('Checkpoint page: exercise set "a1/checkpoint-a1" not found');
---

<Base title="Checkpoint A1">
  <nav class="mb-4 text-sm text-stone-400">
    <a href={withBase('/topics')} class="hover:text-stone-600 dark:hover:text-stone-200">Themen</a>
    <span> / A1</span>
  </nav>

  <header class="mb-8">
    <div class="flex flex-wrap items-center gap-2 text-xs">
      <span class="rounded-full bg-amber-100 px-2.5 py-0.5 font-bold text-amber-800 dark:bg-amber-900 dark:text-amber-200">
        A1
      </span>
      <span class="rounded-full bg-stone-200 px-2.5 py-0.5 font-medium text-stone-600 dark:bg-stone-700 dark:text-stone-300">
        Checkpoint
      </span>
    </div>
    <h1 class="mt-3 text-3xl font-bold tracking-tight">Checkpoint A1</h1>
    <p class="mt-2 text-stone-500 dark:text-stone-400">
      <span class="lang-en">
        One pass over everything A1: listening, reading, grammar and free production across all ten
        topics. Answer without notes — this measures what you can really do. Your results appear on
        the Fortschritt page, broken down by skill.
      </span>
      <span class="lang-ru">
        Один проход по всему уровню A1: аудирование, чтение, грамматика и свободная речь по всем
        десяти темам. Отвечайте без подсказок — здесь измеряется то, что вы действительно умеете.
        Результаты появятся на странице «Fortschritt» с разбивкой по навыкам.
      </span>
    </p>
  </header>

  <aside class="mb-8 rounded-xl border border-stone-200 bg-stone-50 p-4 text-sm text-stone-600 dark:border-stone-700 dark:bg-stone-900/40 dark:text-stone-400">
    <span class="lang-en">
      Best taken after finishing all A1 lessons — but nothing is locked. If a section feels hard,
      that is useful information, not failure: the weak topics get extra drills.
    </span>
    <span class="lang-ru">
      Лучше всего проходить после всех уроков A1 — но ничего не заблокировано. Если какой-то раздел
      даётся тяжело, это полезная информация, а не провал: по слабым темам появятся дополнительные
      упражнения.
    </span>
  </aside>

  <ExerciseSetIsland client:only="react" setId="a1/checkpoint-a1" set={set.data} />
</Base>
