---
import Base from '../../layouts/Base.astro';
import ExerciseSetIsland from '../../components/exercises/ExerciseSet';
import { getCheckpoints } from '../../lib/content';
import { withBase } from '../../lib/url';

// One page per `role: checkpoint` set, at /checkpoint/<level> (the set's own
// directory, lowercased — so the A1 checkpoint keeps its /checkpoint/a1 URL).
export async function getStaticPaths() {
  const checkpoints = await getCheckpoints();
  return checkpoints.map((checkpoint) => ({
    params: { level: checkpoint.slug },
    props: { checkpoint },
  }));
}

const { checkpoint } = Astro.props;
const { level, setId, title, set } = checkpoint;
---

<Base title={title}>
  <nav class="mb-4 text-sm text-stone-400">
    <a href={withBase('/topics')} class="hover:text-stone-600 dark:hover:text-stone-200">Themen</a>
    <span> / {level}</span>
  </nav>

  <header class="mb-8">
    <div class="flex flex-wrap items-center gap-2 text-xs">
      <span class="rounded-full bg-amber-100 px-2.5 py-0.5 font-bold text-amber-800 dark:bg-amber-900 dark:text-amber-200">
        {level}
      </span>
      <span class="rounded-full bg-stone-200 px-2.5 py-0.5 font-medium text-stone-600 dark:bg-stone-700 dark:text-stone-300">
        Checkpoint
      </span>
    </div>
    <h1 class="mt-3 text-3xl font-bold tracking-tight">{title}</h1>
    <p class="mt-2 text-stone-500 dark:text-stone-400">
      <span class="lang-en">
        One pass over everything {level}: listening, reading, grammar and free production across
        every lesson of the level. Answer without notes — this measures what you can really do. Your
        results appear on the Fortschritt page, broken down by skill.
      </span>
      <span class="lang-ru">
        Один проход по всему уровню {level}: аудирование, чтение, грамматика и свободная речь по всем
        урокам уровня. Отвечайте без подсказок — здесь измеряется то, что вы действительно умеете.
        Результаты появятся на странице «Fortschritt» с разбивкой по навыкам.
      </span>
    </p>
  </header>

  <aside class="mb-8 rounded-xl border border-stone-200 bg-stone-50 p-4 text-sm text-stone-600 dark:border-stone-700 dark:bg-stone-900/40 dark:text-stone-400">
    <span class="lang-en">
      Best taken after finishing all {level} lessons — but nothing is locked. If a section feels
      hard, that is useful information, not failure: the weak topics get extra drills.
    </span>
    <span class="lang-ru">
      Лучше всего проходить после всех уроков уровня {level} — но ничего не заблокировано. Если
      какой-то раздел даётся тяжело, это полезная информация, а не провал: по слабым темам появятся
      дополнительные упражнения.
    </span>
  </aside>

  <ExerciseSetIsland client:only="react" setId={setId} set={set} />
</Base>
