---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Chrome from '../components/Chrome.astro';
import DueBadge from '../components/srs/DueBadge';
import FirstSteps from '../components/today/FirstSteps';
import NextTopic from '../components/today/NextTopic';
import ProbeBacklog from '../components/today/ProbeBacklog';
import SessionDoneBadge from '../components/today/SessionDoneBadge';
import { getAllCards, getCheckpoints, getDeckLevels, getPlacements, getTopicNodes } from '../lib/content';
import { getCurriculum } from '../lib/curriculum';
import { probeFamilies } from '../lib/probes';
import { withBase } from '../lib/url';

const cards = await getAllCards();
const nodes = await getTopicNodes();
const deckLevels = await getDeckLevels();
const { spine } = getCurriculum();

// Probe families are pure content, so they are derived at build time; the backlog card
// island only joins them against the attempt log (probe state is never stored). Same
// tolerance as /session: a set whose topic hasn't landed yet is left out.
const [exercises, topics] = await Promise.all([getCollection('exercises'), getCollection('topics')]);
const topicIds = new Set(topics.map((t) => t.data.id));
const families = probeFamilies(
  exercises
    .filter((e) => topicIds.has(e.data.topic))
    .map((e) => ({
      setId: e.id,
      topicId: e.data.topic,
      role: e.data.role,
      items: e.data.items.map((item) => ({ id: item.id, outcomes: item.outcomes })),
    })),
);

// The card links to the checkpoint the learner is due for; the island decides
// which (lowest level whose lessons are done and whose current item ids are not all covered).
const checkpoints = (await getCheckpoints()).map(({ setId, level, path, title, items }) => ({
  setId,
  level,
  path,
  title,
  items,
}));

// Where a learner with no history starts — the FirstSteps card links straight to it.
const firstNode = nodes.find((node) => node.id === spine[0]);
const first = firstNode && { path: firstNode.path, title_de: firstNode.title_de };
// …and the alternative for someone who does not start from zero. The lowest level's test:
// the entry point must not let a learner skip straight to A2 while A1 is untouched, which
// is the same rule dueCheckpoint encodes.
//
// Every level's setId goes with it, because FirstSteps has to tell a placement attempt
// apart from having started learning — counting one hid this card, and the only link back
// into a half-finished test with it.
const placements = await getPlacements();
const firstPlacement = placements[0];
const placement = firstPlacement && {
  path: firstPlacement.path,
  setIds: placements.map((p) => p.setId),
};
---

<Base title="Heute">
  <h1 class="text-3xl font-bold tracking-tight"><Chrome k="today.greeting" /> 👋</h1>
  <p class="mt-1 text-stone-500 dark:text-stone-400">
    <span class="lang-en">Your German atlas — a textbook, exercises and flashcards in one place.</span>
    <span class="lang-ru">Ваш атлас немецкого — учебник, упражнения и карточки в одном месте.</span>
  </p>

  <FirstSteps client:only="react" first={first} placement={placement} />
  <a
    href={withBase('/session')}
    class="mt-8 block rounded-lg bg-amber-600 p-6 text-white shadow-sm hover:bg-amber-700"
  >
    <p class="text-xl font-bold"><Chrome k="today.startSession" /></p>
    <p class="mt-1 text-sm text-amber-100">
      <span class="lang-en">
        Your daily session: review, mixed training, next topic — about 15 minutes.
      </span>
      <span class="lang-ru">
        Ваша ежедневная сессия: повторение, смешанная тренировка, следующая тема — около 15 минут.
      </span>
    </p>
    <SessionDoneBadge client:only="react" />
  </a>

  <ProbeBacklog client:only="react" families={families} />

  <div class="mt-4 grid gap-4 sm:grid-cols-2">
    <a
      href={withBase('/ueben/wiederholen')}
      class="rounded-lg border border-stone-200 bg-white p-6 hover:border-amber-400 dark:border-stone-700 dark:bg-stone-800 dark:hover:border-amber-500"
    >
      <DueBadge client:only="react" cards={cards} variant="full" gate={{ spine, nodes, deckLevels }} />
      <p class="mt-3 text-sm font-semibold text-amber-700 dark:text-amber-400"><Chrome k="ueben.tabWiederholen" /> →</p>
    </a>

    <div class="rounded-lg border border-stone-200 bg-white p-6 dark:border-stone-700 dark:bg-stone-800">
      <NextTopic client:only="react" spine={spine} nodes={nodes} checkpoints={checkpoints} />
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-lg font-bold"><Chrome k="today.quickAccess" /></h2>
    <div class="mt-3 flex flex-wrap gap-3 text-sm">
      <a href={withBase('/topics')} class="rounded-md border border-stone-300 px-3 py-1.5 font-medium hover:border-amber-500 dark:border-stone-600">
        📚 <Chrome k="topics.tabOverview" />
      </a>
      <a href={withBase('/ueben/wortschatz')} class="rounded-md border border-stone-300 px-3 py-1.5 font-medium hover:border-amber-500 dark:border-stone-600">
        🗂 <Chrome k="ueben.tabWortschatz" />
      </a>
      <a href={withBase('/progress')} class="rounded-md border border-stone-300 px-3 py-1.5 font-medium hover:border-amber-500 dark:border-stone-600">
        📈 <Chrome k="nav.fortschritt" />
      </a>
    </div>
  </section>
</Base>
