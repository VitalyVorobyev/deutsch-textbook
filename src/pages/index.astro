---
import Base from '../layouts/Base.astro';
import DueBadge from '../components/srs/DueBadge';
import FirstSteps from '../components/today/FirstSteps';
import NextTopic from '../components/today/NextTopic';
import SessionDoneBadge from '../components/today/SessionDoneBadge';
import { getAllCards, getDeckLevels, getTopicNodes } from '../lib/content';
import { getCurriculum } from '../lib/curriculum';
import { withBase } from '../lib/url';

const cards = await getAllCards();
const nodes = await getTopicNodes();
const deckLevels = await getDeckLevels();
const { spine } = getCurriculum();

// Where a learner with no history starts — the FirstSteps card links straight to it.
const firstNode = nodes.find((node) => node.id === spine[0]);
const first = firstNode && { path: firstNode.path, title_de: firstNode.title_de };
---

<Base title="Heute">
  <h1 class="text-3xl font-bold tracking-tight">Guten Tag! 👋</h1>
  <p class="mt-1 text-stone-500 dark:text-stone-400">
    <span class="lang-en">Your German atlas — a textbook, exercises and flashcards in one place.</span>
    <span class="lang-ru">Ваш атлас немецкого — учебник, упражнения и карточки в одном месте.</span>
  </p>

  <FirstSteps client:only="react" first={first} />
  <a
    href={withBase('/session')}
    class="mt-8 block rounded-lg bg-amber-600 p-6 text-white shadow-sm hover:bg-amber-700"
  >
    <p class="text-xl font-bold">Session starten →</p>
    <p class="mt-1 text-sm text-amber-100">
      <span class="lang-en">
        Your daily session: review, mixed training, next topic — about 15 minutes.
      </span>
      <span class="lang-ru">
        Ваша ежедневная сессия: повторение, смешанная тренировка, следующая тема — около 15 минут.
      </span>
    </p>
    <SessionDoneBadge client:only="react" />
  </a>

  <div class="mt-4 grid gap-4 sm:grid-cols-2">
    <a
      href={withBase('/ueben/wiederholen')}
      class="rounded-lg border border-stone-200 bg-white p-6 hover:border-amber-400 dark:border-stone-700 dark:bg-stone-800 dark:hover:border-amber-500"
    >
      <DueBadge client:only="react" cards={cards} variant="full" gate={{ spine, nodes, deckLevels }} />
      <p class="mt-3 text-sm font-semibold text-amber-700 dark:text-amber-400">Wiederholen →</p>
    </a>

    <div class="rounded-lg border border-stone-200 bg-white p-6 dark:border-stone-700 dark:bg-stone-800">
      <NextTopic
        client:only="react"
        spine={spine}
        nodes={nodes}
        checkpoint={{ path: withBase('/checkpoint/a1'), setId: 'a1/checkpoint-a1', level: 'A1', title: 'Checkpoint A1' }}
      />
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-lg font-bold">Schnellzugriff</h2>
    <div class="mt-3 flex flex-wrap gap-3 text-sm">
      <a href={withBase('/topics')} class="rounded-md border border-stone-300 px-3 py-1.5 font-medium hover:border-amber-500 dark:border-stone-600">
        📚 Alle Themen
      </a>
      <a href={withBase('/ueben/wortschatz')} class="rounded-md border border-stone-300 px-3 py-1.5 font-medium hover:border-amber-500 dark:border-stone-600">
        🗂 Wortschatz
      </a>
      <a href={withBase('/progress')} class="rounded-md border border-stone-300 px-3 py-1.5 font-medium hover:border-amber-500 dark:border-stone-600">
        📈 Fortschritt
      </a>
    </div>
  </section>
</Base>
