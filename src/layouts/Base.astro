---
import '../styles/global.css';
import ProfileSwitcher from '../components/ProfileSwitcher';
import FirstRunGate from '../components/FirstRunGate';
import { withBase } from '../lib/url';
import { UI_LANGS, t, type StringKey } from '../lib/strings';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Deutsch-Atlas — ein interaktives Lehrbuch' } = Astro.props;

const home = withBase('/');
interface NavItem {
  href: string;
  /** Chrome-string key: all UI languages render as CSS-toggled spans. */
  label: StringKey;
  /** Extra path prefixes that also count as "this tab" (e.g. /vocab/<deck> → Üben). */
  match?: string[];
}
const nav: NavItem[] = [
  { href: home, label: 'nav.heute' },
  { href: withBase('/topics'), label: 'nav.themen' },
  { href: withBase('/entdecken'), label: 'nav.entdecken' },
  { href: withBase('/referenz'), label: 'nav.referenz' },
  { href: withBase('/ueben'), label: 'nav.ueben', match: [withBase('/vocab')] },
  { href: withBase('/progress'), label: 'nav.fortschritt' },
  { href: withBase('/about'), label: 'nav.ueber' },
];
const current = Astro.url.pathname;
function isActive(item: NavItem): boolean {
  if (item.href === home) return current === home || current === home.replace(/\/$/, '');
  return [item.href, ...(item.match ?? [])].some((prefix) => current.startsWith(prefix));
}
---

<!doctype html>
<html lang="en" data-explain-lang="en" data-ui-lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={withBase('/favicon.png')} />
    <title>{title} · Deutsch-Atlas</title>
    <script is:inline>
      (function () {
        let theme = localStorage.getItem('da:theme');
        if (!theme) theme = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.dataset.theme = theme;
        // Language prefs are profile-scoped; this mirrors resolveExplainLang/
        // resolveUiLang in src/lib/prefs.ts (keep in sync) because a pre-paint
        // script cannot import. Profile resolution mirrors getActiveProfileId
        // in src/lib/profile.ts: da:profile, else first registered, else 'local'.
        let pid = localStorage.getItem('da:profile');
        if (!pid) {
          try {
            const list = JSON.parse(localStorage.getItem('da:profiles') || 'null');
            if (Array.isArray(list) && list[0] && typeof list[0].id === 'string') pid = list[0].id;
          } catch {
            /* unreadable registry — fall through to the anonymous id */
          }
        }
        if (!pid) pid = 'local';
        // Own-key check mirrors isExplainLang: the four-value EXPLAIN_LANGS set.
        let lang = localStorage.getItem('da:lang:' + pid);
        if (lang !== 'en' && lang !== 'ru' && lang !== 'uk' && lang !== 'de') {
          // First read for this profile: copy the legacy device-level choice
          // forward, but leave da:lang in place as the device default that the
          // next new profile inherits. The legacy key predates uk/de and is
          // never written anymore, so it deliberately stays en/ru-only.
          const legacy = localStorage.getItem('da:lang');
          if (legacy === 'ru' || legacy === 'en') {
            lang = legacy;
            localStorage.setItem('da:lang:' + pid, legacy);
          }
        }
        if (lang === 'en' || lang === 'ru' || lang === 'uk' || lang === 'de')
          document.documentElement.dataset.explainLang = lang;
        const ui = localStorage.getItem('da:uilang:' + pid);
        if (ui === 'en' || ui === 'ru' || ui === 'uk') document.documentElement.dataset.uiLang = ui;
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <FirstRunGate client:only="react" />
    <header class="sticky top-0 z-10 border-b border-stone-200 bg-stone-50/90 backdrop-blur dark:border-stone-700 dark:bg-stone-900/90">
      <div class="mx-auto flex max-w-4xl flex-wrap items-center gap-x-6 gap-y-1 px-4 py-3">
        <a href={home} class="text-lg font-bold tracking-tight text-stone-900 dark:text-stone-100">
          Deutsch-<span class="text-amber-600 dark:text-amber-400">Atlas</span>
        </a>
        <nav class="order-3 -mx-4 flex w-full gap-x-4 overflow-x-auto whitespace-nowrap px-4 text-sm sm:order-none sm:mx-0 sm:w-auto sm:flex-wrap sm:overflow-visible sm:whitespace-normal sm:px-0">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'py-2 font-medium sm:py-1',
                  isActive(item)
                    ? 'text-amber-700 dark:text-amber-400'
                    : 'text-stone-600 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100',
                ]}
              >
                {UI_LANGS.map((l) => (
                  <span class={`ui-${l}`}>{t(item.label, l)}</span>
                ))}
              </a>
            ))
          }
        </nav>
        <div class="ml-auto flex items-center gap-2">
          <ProfileSwitcher client:only="react" />
          <div class="flex overflow-hidden rounded-md border border-stone-300 text-xs dark:border-stone-600" role="group" aria-label="Explanation language">
            <button type="button" data-lang-btn="en" class="px-2.5 py-1.5 font-semibold sm:px-2 sm:py-1">EN</button>
            <button type="button" data-lang-btn="ru" class="px-2.5 py-1.5 font-semibold sm:px-2 sm:py-1">RU</button>
            <button type="button" data-lang-btn="uk" class="px-2.5 py-1.5 font-semibold sm:px-2 sm:py-1">UK</button>
            <button type="button" data-lang-btn="de" class="px-2.5 py-1.5 font-semibold sm:px-2 sm:py-1">DE</button>
          </div>
          <button
            type="button"
            id="theme-toggle"
            class="rounded-md border border-stone-300 px-2.5 py-1.5 text-xs dark:border-stone-600 sm:px-2 sm:py-1"
            aria-label="Toggle dark mode"
          >
            <span class="dark:hidden">🌙</span><span class="hidden dark:inline">☀️</span>
          </button>
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-4xl flex-1 px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-stone-200 py-6 text-center text-xs text-stone-500 dark:border-stone-700 dark:text-stone-400">
      {UI_LANGS.map((l) => <span class={`ui-${l}`}>{t('footer.tagline', l)}</span>)}
    </footer>

    <script>
      import { setExplainLang, setTheme, getExplainLang, type ExplainLang } from '../lib/prefs';

      function paintLangButtons() {
        const active = getExplainLang();
        document.querySelectorAll<HTMLButtonElement>('[data-lang-btn]').forEach((btn) => {
          const isActive = btn.dataset.langBtn === active;
          btn.classList.toggle('bg-amber-500', isActive);
          btn.classList.toggle('text-white', isActive);
        });
      }

      document.querySelectorAll<HTMLButtonElement>('[data-lang-btn]').forEach((btn) => {
        btn.addEventListener('click', () => {
          setExplainLang(btn.dataset.langBtn as ExplainLang);
          paintLangButtons();
        });
      });

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        setTheme(next);
      });

      paintLangButtons();
    </script>
  </body>
</html>
