---
import type { VocabEntry } from '../lib/schemas';
import SpeakButton from './SpeakButton.astro';

interface Props {
  entries: VocabEntry[];
}
const { entries } = Astro.props;

function headword(e: VocabEntry): string {
  if (e.pos === 'noun' && e.gender) {
    const article = { m: 'der', f: 'die', n: 'das' }[e.gender];
    return `${article} ${e.de}`;
  }
  return e.de;
}

function forms(e: VocabEntry): string {
  if (e.pos === 'noun') return e.plural ?? '';
  if (e.pos === 'verb') {
    const parts: string[] = [];
    if (e.praesens_3sg) parts.push(e.praesens_3sg);
    if (e.partizip2) parts.push(`${e.aux === 'sein' ? 'ist' : 'hat'} ${e.partizip2}`);
    if (e.valence) parts.push(e.valence);
    return parts.join(', ');
  }
  return e.valence ?? '';
}
---

<div class="overflow-x-auto">
  <table class="w-full border-collapse text-sm max-sm:block">
    <thead class="max-sm:hidden">
      <tr class="border-b-2 border-stone-300 text-left dark:border-stone-600">
        <th class="py-2 pr-4 font-semibold">Wort</th>
        <th class="py-2 pr-4 font-semibold">Formen</th>
        <th class="py-2 pr-4 font-semibold">
          {/* .lang-uk spans are conditional: where an entry has no uk gloss the
              EN span stays visible under uk mode (the :has() fallback in
              global.css), so the header only claims Ukrainian when some entry
              actually carries it. No .lang-de spans exist — a vocab entry has
              no German gloss by design. */}
          <span class="lang-en">English</span><span class="lang-ru">Русский</span>
          {entries.some((e) => e.uk) && <span class="lang-uk">Українська</span>}
        </th>
        <th class="py-2 font-semibold">Beispiel</th>
      </tr>
    </thead>
    <tbody class="max-sm:block">
      {
        entries.map((e) => (
          <tr class="border-b border-stone-200 align-top max-sm:mb-3 max-sm:block max-sm:rounded-lg max-sm:border max-sm:p-3 dark:border-stone-700">
            <td class="py-2 pr-4 max-sm:block max-sm:py-0.5 max-sm:pr-0">
              <span class="flex items-center gap-1">
                <span lang="de" class="font-medium sm:whitespace-nowrap">{headword(e)}</span>
                <SpeakButton text={headword(e)} class="shrink-0 text-stone-400" />
              </span>
              {e.ipa && (
                <span translate="no" class="block text-xs text-stone-400 dark:text-stone-500">
                  [{e.ipa}]
                </span>
              )}
            </td>
            <td lang="de" class="py-2 pr-4 text-stone-500 max-sm:block max-sm:py-0.5 max-sm:pr-0 dark:text-stone-400">{forms(e)}</td>
            <td class="py-2 pr-4 max-sm:block max-sm:py-0.5 max-sm:pr-0">
              <span class="lang-en">{e.en}</span>
              <span class="lang-ru">{e.ru}</span>
              {e.uk && <span class="lang-uk">{e.uk}</span>}
              {e.note && (
                <span class="block text-xs text-stone-400">
                  <span class="lang-en">{e.note.en}</span>
                  <span class="lang-ru">{e.note.ru}</span>
                  {e.note.uk && <span class="lang-uk">{e.note.uk}</span>}
                </span>
              )}
            </td>
            <td class="py-2 max-sm:block max-sm:py-0.5">
              <span class="flex items-start gap-1">
                <span lang="de" class="min-w-0 flex-1">{e.example_de}</span>
                <SpeakButton
                  text={e.example_de}
                  label={`Beispiel anhören: ${e.example_de}`}
                  class="shrink-0 text-stone-400"
                />
              </span>
              <span class="block text-xs italic text-stone-400">
                <span class="lang-en">{e.example_en}</span>
                <span class="lang-ru">{e.example_ru}</span>
                {e.example_uk && <span class="lang-uk">{e.example_uk}</span>}
              </span>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
