---
/**
 * One chrome string, rendered in German — the pinned chrome language
 * (resolveUiLang in src/lib/prefs.ts has the rationale). Kept as a component
 * so static pages have one seam if the pin is ever lifted.
 */
import { t, type StringKey } from '../lib/strings';

interface Props {
  k: StringKey;
}
const { k } = Astro.props;
---

{t(k, 'de')}
